{
  "manifest_version": 3,
  "name": "New Tab Blocker",
  "description": "指定ドメインの新規タブを自動で即閉じる拡張機能",
  "version": "1.0.0",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked_domains.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
